    {
      "name": "FIELD BOOKINGS",
      "description": "Field booking system endpoints",
      "item": [
        {
          "name": "Get Field Operating Hours",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings/fields/field-uuid/hours",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bookings",
                "fields",
                "field-uuid",
                "hours"
              ]
            },
            "description": "Get operating hours for a specific field\n\nResponse:\n{\n  \"success\": true,\n  \"data\": [\n    {\n      \"day_of_week\": 0,\n      \"opening_time\": \"08:00:00\",\n      \"closing_time\": \"22:00:00\"\n    }\n  ]\n}"
          },
          "response": []
        },
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bookings"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userType\": \"member\",\n  \"userId\": \"user-uuid\",\n  \"sport_id\": 1,\n  \"field_id\": \"field-uuid\",\n  \"start_time\": \"2025-03-15T10:00:00Z\",\n  \"end_time\": \"2025-03-15T11:00:00Z\",\n  \"expected_participants\": 10,\n  \"notes\": \"Team training session\",\n  \"language\": \"ar\"\n}"
            },
            "description": "Create a new field booking\n\nRequired fields:\n- userType: \"member\" | \"team_member\"\n- userId: UUID of the user\n- sport_id: Integer ID of the sport\n- field_id: UUID of the field\n- start_time: ISO datetime string\n- end_time: ISO datetime string\n- expected_participants: Positive integer\n- language: \"ar\" | \"en\"\n\nResponse (201):\n{\n  \"success\": true,\n  \"data\": {\n    \"id\": \"booking-uuid\",\n    \"sport_id\": 1,\n    \"field_id\": \"field-uuid\",\n    \"start_time\": \"2025-03-15T10:00:00Z\",\n    \"end_time\": \"2025-03-15T11:00:00Z\",\n    \"duration_minutes\": 60,\n    \"price\": 150.00,\n    \"status\": \"pending_payment\",\n    \"share_token\": \"abc123...\",\n    \"share_url\": \"http://localhost:3000/bookings/share/abc123...\",\n    \"expected_participants\": 10,\n    \"participants\": [...],\n    \"created_at\": \"2025-03-01T10:00:00Z\"\n  },\n  \"message\": \"Booking created successfully. Please proceed to payment.\"\n}"
          },
          "response": []
        },
        {
          "name": "Get Booking Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookings/booking-uuid",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bookings",
                "booking-uuid"
              ]
            },
            "description": "Get detailed information about a specific booking"
          },
          "response": []
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookings/booking-uuid/confirm-payment",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bookings",
                "booking-uuid",
                "confirm-payment"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentReference\": \"PAYMENT_ID_FROM_GATEWAY\"\n}"
            },
            "description": "Confirm booking after successful payment\n\nChanges booking status from 'pending_payment' to 'confirmed'"
          },
          "response": []
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookings/booking-uuid",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bookings",
                "booking-uuid"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Schedule conflict\"\n}"
            },
            "description": "Cancel a booking with optional reason"
          },
          "response": []
        },
        {
          "name": "Get User Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookings/users/member/user-uuid",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bookings",
                "users",
                "member",
                "user-uuid"
              ]
            },
            "description": "Get all bookings for a specific user\n\nParams:\n- userType: \"member\" | \"team_member\"\n- userId: UUID of the user\n\nResponse:\n{\n  \"success\": true,\n  \"data\": [...],\n  \"count\": 5\n}"
          },
          "response": []
        },
        {
          "name": "Get Booking Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookings/stats/member/user-uuid",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bookings",
                "stats",
                "member",
                "user-uuid"
              ]
            },
            "description": "Get booking statistics for a user\n\nResponse:\n{\n  \"success\": true,\n  \"data\": {\n    \"total_bookings\": 10,\n    \"confirmed_bookings\": 8,\n    \"total_participants\": 45,\n    \"total_revenue\": 1200.00\n  }\n}"
          },
          "response": []
        }
      ]
