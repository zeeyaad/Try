                "share",
                "share-token",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"أحمد علي\",\n  \"phone_number\": \"+201001234567\",\n  \"national_id\": \"29001011234567\",\n  \"email\": \"ahmed@example.com\"\n}"
            },
            "description": "Register as a participant via shared booking link (public)\n\nNote: At least one contact method (phone_number, national_id, or email) is required\n\nResponse (201):\n{\n  \"success\": true,\n  \"data\": {\n    \"id\": \"participant-uuid\",\n    \"full_name\": \"أحمد علي\",\n    \"phone_number\": \"+201001234567\",\n    \"national_id\": \"29001011234567\",\n    \"email\": \"ahmed@example.com\",\n    \"is_creator\": false\n  },\n  \"message\": \"You have been successfully registered for this booking!\"\n}"
          },
          "response": []
        }
      ]
    }
