              "raw": "{\n  \"first_name_en\": \"Ahmed\",\n  \"first_name_ar\": \"أحمد\",\n  \"last_name_en\": \"Hassan\",\n  \"last_name_ar\": \"حسن\",\n  \"national_id\": \"12345678901234\",\n  \"phone\": \"+201234567890\",\n  \"address\": \"Cairo, Egypt\",\n  \"staff_type_id\": 4,\n  \"employment_start_date\": \"2024-01-15\",\n  \"employment_end_date\": null\n}"
