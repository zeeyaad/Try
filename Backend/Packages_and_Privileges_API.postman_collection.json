                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/staff/packages/{{package_id}}/privileges",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "staff",
                "packages",
