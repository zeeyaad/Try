  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec node -r ts-node/register src/index.ts",
    "build": "tsc",
    "migrate": "node -r ts-node/register src/scripts/runMigrations.ts",
    "fix:accounts-constraint": "node -r ts-node/register src/scripts/fix-accounts-constraint.ts",
    "fix:all-tables": "node -r ts-node/register src/scripts/fix-all-detail-tables.ts",
    "fix:student-table": "node -r ts-node/register src/scripts/fix-student-details-table.ts",
    "fix:employee-table": "node -r ts-node/register src/scripts/fix-employee-details-table.ts",
    "fix:retired-table": "node -r ts-node/register src/scripts/fix-retired-details-table.ts",
    "fix:memberships-table": "node -r ts-node/register src/scripts/fix-member-memberships-table.ts",
    "add:professions": "node -r ts-node/register src/scripts/add-sample-professions.ts",
    "add:sport-staff-types": "node -r ts-node/register src/scripts/add-sport-staff-types.ts",
    "create:sport-test-accounts": "node -r ts-node/register src/scripts/create-sport-test-accounts.ts",
    "create:media-account": "node -r ts-node/register --transpile-only src/scripts/create-media-account.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.91.1",
    "@types/multer": "^2.0.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "express": "^5.1.0",
    "express-validator": "^7.3.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^12.2.0",
    "multer": "^2.0.2",
    "mysql": "^2.18.1",
    "nodemon": "^3.1.10",
    "pg": "^8.17.2",
    "psql": "^0.0.1",
    "reflect-metadata": "^0.2.2",
    "stripe": "^20.4.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.2",
    "@types/pg": "^8.16.0",
    "supabase": "^2.72.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
